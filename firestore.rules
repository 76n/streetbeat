rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid);
      allow update, delete: if isOwner(uid);
    }

    match /runs/{runId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn() && (
        (resource.data.uid == request.auth.uid)
        || (
          resource.data.uid == request.resource.data.uid
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['kudosUserIds', 'kudosCount'])
        )
      );
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /segments/{segmentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create, update: if false;
      allow delete: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }

    match /leaderboardCache/{scope} {
      allow read: if signedIn();
      allow write: if false;

      match /entries/{uid} {
        allow read: if signedIn();
        allow write: if false;
      }
    }

    match /clubs/{clubId} {
      allow read: if signedIn();
      allow write: if false;

      match /weeklyStats/{weekId} {
        allow read: if signedIn();
        allow write: if false;
      }
    }

    match /users/{uid}/ghost_segments/{segmentKey} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && request.auth.uid == uid;
    }
  }
}
