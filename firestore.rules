rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }

    match /runs/{runId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (
        (resource.data.uid == request.auth.uid)
        || (
          resource.data.uid == request.resource.data.uid
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['kudosUserIds', 'kudosCount'])
        )
      );
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /segments/{segmentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create, update: if false;
      allow delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }

    match /leaderboardCache/{docId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /entries/{uid} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /weeklyStats/{weekId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /users/{uid}/ghost_segments/{segmentKey} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
